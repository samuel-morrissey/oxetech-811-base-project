# Copie este arquivo para .env (cp .env.example .env) e os valores ja apontam
# para os servicos definidos no docker-compose.yml.

PORT=3000

# PostgreSQL (servico "postgres" do docker-compose)
DATABASE_URL=postgresql://oxetech:oxetech@localhost:5432/oxetech?schema=public

# SMTP / Mailpit (servico "mailpit" do docker-compose)
# Interface web para inspecionar os emails: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=Oxetech Helpdesk <no-reply@oxetech.com>
